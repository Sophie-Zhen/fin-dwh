# Copy this file to ".env" and fill in your real values.
# .env is gitignored — never commit it.
# If any value contains special characters (#, $, spaces), wrap it in single quotes.

# --- Snowflake (from your 30-day trial account) ------------------------------
# Account identifier: in Snowsight, Admin > Accounts, or the part of your login
# URL before ".snowflakecomputing.com" (e.g. "ab12345.eu-west-1" or "ORG-ACCOUNT").
SNOWFLAKE_ACCOUNT=your_account_identifier
SNOWFLAKE_USER=your_user
SNOWFLAKE_PASSWORD=your_password
SNOWFLAKE_ROLE=ACCOUNTADMIN
SNOWFLAKE_WAREHOUSE=FIN_WH
SNOWFLAKE_DATABASE=FIN_DWH
SNOWFLAKE_SCHEMA=MARTS

# --- Google Gemini (primary natural-language-to-SQL provider) ----------------
# Free API key from https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key
# Gemini model used to translate English to SQL. Set this to whatever the latest
# model is on your account if a newer one than 2.5-pro is available.
GEMINI_MODEL=gemini-2.5-pro

# --- Anthropic / Claude (fallback if the Gemini call fails) ------------------
# Optional but recommended. Key from https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-your-key-here
ANTHROPIC_MODEL=claude-opus-4-8
